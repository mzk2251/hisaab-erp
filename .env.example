# Database (Railway PostgreSQL auto-populates this)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Backend
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-characters
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Frontend (Vite) — not needed in production (served from same origin)
# VITE_API_URL=http://localhost:4000/api
